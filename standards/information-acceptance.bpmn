<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_IPM" targetNamespace="https://bimfabrik.github.io/ipm/bpmn">
  <bpmn:collaboration id="Collaboration_InformationAcceptance">
    <bpmn:participant id="Participant_Project" name="Project information delivery and acceptance" processRef="Process_InformationAcceptance" />
  </bpmn:collaboration>
  <bpmn:process id="Process_InformationAcceptance" name="Requirement to acceptance" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Client" name="Client / Information Management">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefineRequirement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfigureUseCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AssignProcess</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Delivery" name="Responsible Delivery Team">
        <bpmn:flowNodeRef>Task_ExecuteProcess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProduceEvidence</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CorrectDelivery</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Review" name="Reviewer / Approver">
        <bpmn:flowNodeRef>Task_ReviewEvidence</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Accepted</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RecordAcceptance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_1" name="Information need identified">
      <bpmn:documentation>A decision, operational outcome or contractual need triggers the information-ordering process.</bpmn:documentation>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_DefineRequirement" name="Define and approve requirement">
      <bpmn:documentation>State the purpose, expected outcome, applicability and acceptance criteria. Link the requirement to its governing standard or project decision.</bpmn:documentation>
      <bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ConfigureUseCase" name="Select or configure use case">
      <bpmn:documentation>Choose the business use case that explains why the information is required and which decisions or processes it supports.</bpmn:documentation>
      <bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AssignProcess" name="Assign responsible process and role">
      <bpmn:documentation>Identify the accountable process, producer, reviewer and milestone. Responsibility must be explicit before information is requested.</bpmn:documentation>
      <bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ExecuteProcess" name="Execute responsible information process">
      <bpmn:documentation>Produce or update the required information through the assigned project process, using the agreed source systems and exchange format.</bpmn:documentation>
      <bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ProduceEvidence" name="Deliver information and evidence">
      <bpmn:documentation>Submit the information product together with evidence such as IFC, IDS validation results, documents, approvals or system records.</bpmn:documentation>
      <bpmn:incoming>Flow_5</bpmn:incoming><bpmn:incoming>Flow_10</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReviewEvidence" name="Review evidence against criteria">
      <bpmn:documentation>Compare the delivery with the approved requirement and acceptance criteria. Record findings and exceptions.</bpmn:documentation>
      <bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Accepted" name="Accepted?">
      <bpmn:documentation>The reviewer determines whether the delivery is complete, compliant and suitable for its intended use.</bpmn:documentation>
      <bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing><bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_CorrectDelivery" name="Correct delivery">
      <bpmn:documentation>Resolve rejected or incomplete information, update the evidence and resubmit it for review.</bpmn:documentation>
      <bpmn:incoming>Flow_9</bpmn:incoming><bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RecordAcceptance" name="Record acceptance">
      <bpmn:documentation>Store the approval, accepted evidence, date, responsible approver and any residual conditions in the project record.</bpmn:documentation>
      <bpmn:incoming>Flow_8</bpmn:incoming><bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_1" name="Accepted information available">
      <bpmn:documentation>The accepted information becomes available for the intended decision, delivery process or operational system.</bpmn:documentation>
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:dataObject id="DataObject_Requirement" /><bpmn:dataObjectReference id="DataRef_Requirement" name="Approved requirement" dataObjectRef="DataObject_Requirement" />
    <bpmn:dataObject id="DataObject_UseCase" /><bpmn:dataObjectReference id="DataRef_UseCase" name="Use-case definition" dataObjectRef="DataObject_UseCase" />
    <bpmn:dataObject id="DataObject_Criteria" /><bpmn:dataObjectReference id="DataRef_Criteria" name="Acceptance criteria / IDS" dataObjectRef="DataObject_Criteria" />
    <bpmn:dataObject id="DataObject_Evidence" /><bpmn:dataObjectReference id="DataRef_Evidence" name="Delivery evidence" dataObjectRef="DataObject_Evidence" />
    <bpmn:dataObject id="DataObject_Acceptance" /><bpmn:dataObjectReference id="DataRef_Acceptance" name="Acceptance record" dataObjectRef="DataObject_Acceptance" />

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_DefineRequirement" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_DefineRequirement" targetRef="Task_ConfigureUseCase" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_ConfigureUseCase" targetRef="Task_AssignProcess" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_AssignProcess" targetRef="Task_ExecuteProcess" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_ExecuteProcess" targetRef="Task_ProduceEvidence" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_ProduceEvidence" targetRef="Task_ReviewEvidence" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_ReviewEvidence" targetRef="Gateway_Accepted" />
    <bpmn:sequenceFlow id="Flow_8" name="Yes" sourceRef="Gateway_Accepted" targetRef="Task_RecordAcceptance" />
    <bpmn:sequenceFlow id="Flow_9" name="No" sourceRef="Gateway_Accepted" targetRef="Task_CorrectDelivery" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_CorrectDelivery" targetRef="Task_ProduceEvidence" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_RecordAcceptance" targetRef="EndEvent_1" />

    <bpmn:association id="Association_Requirement" sourceRef="DataRef_Requirement" targetRef="Task_DefineRequirement" />
    <bpmn:association id="Association_UseCase" sourceRef="Task_ConfigureUseCase" targetRef="DataRef_UseCase" />
    <bpmn:association id="Association_Criteria" sourceRef="DataRef_Criteria" targetRef="Task_ReviewEvidence" />
    <bpmn:association id="Association_Evidence" sourceRef="Task_ProduceEvidence" targetRef="DataRef_Evidence" />
    <bpmn:association id="Association_Acceptance" sourceRef="Task_RecordAcceptance" targetRef="DataRef_Acceptance" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_InformationAcceptance">
      <bpmndi:BPMNShape id="Participant_Project_di" bpmnElement="Participant_Project" isHorizontal="true"><dc:Bounds x="70" y="90" width="1770" height="600" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Client_di" bpmnElement="Lane_Client" isHorizontal="true"><dc:Bounds x="100" y="90" width="1740" height="190" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Delivery_di" bpmnElement="Lane_Delivery" isHorizontal="true"><dc:Bounds x="100" y="280" width="1740" height="190" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Review_di" bpmnElement="Lane_Review" isHorizontal="true"><dc:Bounds x="100" y="470" width="1740" height="220" /></bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1"><dc:Bounds x="145" y="155" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="123" y="197" width="82" height="28" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DefineRequirement_di" bpmnElement="Task_DefineRequirement"><dc:Bounds x="235" y="132" width="150" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConfigureUseCase_di" bpmnElement="Task_ConfigureUseCase"><dc:Bounds x="445" y="132" width="150" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssignProcess_di" bpmnElement="Task_AssignProcess"><dc:Bounds x="655" y="132" width="165" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ExecuteProcess_di" bpmnElement="Task_ExecuteProcess"><dc:Bounds x="765" y="335" width="180" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProduceEvidence_di" bpmnElement="Task_ProduceEvidence"><dc:Bounds x="1010" y="335" width="175" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewEvidence_di" bpmnElement="Task_ReviewEvidence"><dc:Bounds x="1190" y="535" width="175" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Accepted_di" bpmnElement="Gateway_Accepted" isMarkerVisible="true"><dc:Bounds x="1420" y="550" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="1409" y="606" width="72" height="18" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CorrectDelivery_di" bpmnElement="Task_CorrectDelivery"><dc:Bounds x="1320" y="335" width="145" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordAcceptance_di" bpmnElement="Task_RecordAcceptance"><dc:Bounds x="1530" y="535" width="145" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1"><dc:Bounds x="1740" y="557" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="1700" y="600" width="116" height="28" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="DataRef_Requirement_di" bpmnElement="DataRef_Requirement"><dc:Bounds x="270" y="225" width="36" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="310" y="234" width="100" height="28" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataRef_UseCase_di" bpmnElement="DataRef_UseCase"><dc:Bounds x="500" y="220" width="36" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="540" y="230" width="100" height="28" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataRef_Evidence_di" bpmnElement="DataRef_Evidence"><dc:Bounds x="1080" y="420" width="36" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="1120" y="432" width="96" height="18" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataRef_Criteria_di" bpmnElement="DataRef_Criteria"><dc:Bounds x="1220" y="625" width="36" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="1260" y="635" width="120" height="28" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataRef_Acceptance_di" bpmnElement="DataRef_Acceptance"><dc:Bounds x="1585" y="625" width="36" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="1625" y="635" width="102" height="18" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1"><di:waypoint x="181" y="173" /><di:waypoint x="235" y="173" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2"><di:waypoint x="385" y="172" /><di:waypoint x="445" y="172" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3"><di:waypoint x="595" y="172" /><di:waypoint x="655" y="172" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4"><di:waypoint x="738" y="212" /><di:waypoint x="738" y="375" /><di:waypoint x="765" y="375" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5"><di:waypoint x="945" y="375" /><di:waypoint x="1010" y="375" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6"><di:waypoint x="1185" y="375" /><di:waypoint x="1278" y="375" /><di:waypoint x="1278" y="535" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7"><di:waypoint x="1365" y="575" /><di:waypoint x="1420" y="575" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8"><di:waypoint x="1470" y="575" /><di:waypoint x="1530" y="575" /><bpmndi:BPMNLabel><dc:Bounds x="1486" y="555" width="18" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9"><di:waypoint x="1445" y="550" /><di:waypoint x="1445" y="455" /><di:waypoint x="1393" y="455" /><di:waypoint x="1393" y="415" /><bpmndi:BPMNLabel><dc:Bounds x="1452" y="468" width="14" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10"><di:waypoint x="1320" y="375" /><di:waypoint x="1185" y="375" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11"><di:waypoint x="1675" y="575" /><di:waypoint x="1740" y="575" /></bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Association_Requirement_di" bpmnElement="Association_Requirement"><di:waypoint x="288" y="225" /><di:waypoint x="310" y="212" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Association_UseCase_di" bpmnElement="Association_UseCase"><di:waypoint x="520" y="212" /><di:waypoint x="518" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Association_Evidence_di" bpmnElement="Association_Evidence"><di:waypoint x="1098" y="415" /><di:waypoint x="1098" y="420" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Association_Criteria_di" bpmnElement="Association_Criteria"><di:waypoint x="1238" y="625" /><di:waypoint x="1278" y="615" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Association_Acceptance_di" bpmnElement="Association_Acceptance"><di:waypoint x="1603" y="615" /><di:waypoint x="1603" y="625" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
